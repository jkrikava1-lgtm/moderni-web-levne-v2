---
import data from '../content/services.json';
const services = data.items;
---

<section id="sluzby" class="pt-24 md:pt-32 pb-12 md:pb-16">
  <div class="max-w-[1400px] mx-auto px-4 md:px-8">
    <!-- Section header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14 reveal">
      <div>
        <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-4">Služby</div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight">
          {data.heading}
        </h2>
      </div>
      <p class="text-text-secondary max-w-md text-lg leading-relaxed">
        {data.subtext}
      </p>
    </div>

    <!-- Service items — staggered list (inspired by AKQA/Clay) -->
    <div class="space-y-0">
      {services.map((service) => (
        <div class="reveal group border-t border-dark-border py-10 md:py-14" data-hover>
          <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-16">
            <div class="text-text-muted text-sm font-mono md:w-16 shrink-0">{service.num}</div>
            <div class="flex-1">
              <h3 class="text-2xl md:text-3xl font-semibold tracking-tight group-hover:text-accent transition-colors duration-500">
                {service.title}
              </h3>
              <p class="text-text-secondary text-base mt-4 max-w-lg leading-relaxed">
                {service.description}
              </p>
              <div class="flex flex-wrap gap-2 mt-5">
                {service.tags.map((tag) => (
                  <span class="px-3 py-1 border border-dark-border rounded-full text-sm text-text-muted">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
            <div class="hidden md:flex items-center opacity-0 group-hover:opacity-100 transition-opacity duration-500">
              <div class="w-10 h-10 rounded-full border border-accent/30 flex items-center justify-center group-hover:bg-accent group-hover:border-accent transition-all duration-500">
                <svg class="w-4 h-4 text-accent group-hover:text-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
