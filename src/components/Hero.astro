---
import hero from '../content/hero.json';
---

<section class="relative pt-24 md:pt-36 xl:pt-48 pb-16 md:pb-24 overflow-hidden" id="hero">
  <div class="relative z-10 max-w-[1400px] mx-auto px-4 md:px-8 w-full">
    <div class="mb-8 overflow-hidden">
      <div class="text-text-secondary text-xs tracking-[0.3em] uppercase">
        {hero.label}
      </div>
    </div>

    <div class="relative inline-block">
      <h1 class="split-text text-[clamp(2.5rem,8vw,8rem)] font-bold leading-[0.95] tracking-tight" id="hero-text">
        {hero.headline_line1}<br/>
        <span class="text-accent">{hero.headline_line2}</span>
      </h1>
      <div class="h-[3px] bg-accent mt-4 md:hidden" id="hero-line"></div>
    </div>

    <div class="mt-16 flex flex-col md:flex-row items-start md:items-end justify-between gap-8 border-t border-dark-border pt-8">
      <p class="text-text-secondary text-lg md:text-xl max-w-md leading-relaxed" id="hero-subtext" data-text={hero.subtext}>
        {hero.subtext}
      </p>

      <div class="flex items-center gap-6">
        <a href="#kontakt" class="magnetic-btn group flex items-center gap-3 text-white" data-hover>
          <span class="text-base tracking-wider uppercase">{hero.cta_text}</span>
          <span class="w-12 h-12 rounded-full border border-accent/40 flex items-center justify-center group-hover:bg-accent group-hover:border-accent transition-all duration-500">
            <svg class="w-4 h-4 text-accent group-hover:text-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-8 w-px h-16 bg-gradient-to-b from-transparent to-accent/30"></div>
</section>

<script>
  const heroText = document.getElementById('hero-text');
  if (heroText) {
    const lines = heroText.innerHTML.split(/<br\s*\/?>/i);
    let wordIndex = 0;
    const processedLines = lines.map((line) => {
      const parts = line.split(/(\s+|<[^>]+>)/);
      return parts.map((part) => {
        if (part.match(/^</) || part.match(/^\s*$/)) return part;
        wordIndex++;
        const delay = wordIndex * 0.18;
        return `<span class="word"><span class="word-inner" style="transition-delay: ${delay}s">${part}</span></span>`;
      }).join('');
    });
    heroText.innerHTML = processedLines.join('<br/>');
    setTimeout(() => heroText.classList.add('revealed'), 1500);
  }

  // Typing effect — desktop only
  if (window.matchMedia('(pointer: fine)').matches) {
    const subtext = document.getElementById('hero-subtext');
    if (subtext) {
      const fullText = subtext.getAttribute('data-text') || '';
      const height = subtext.offsetHeight;
      subtext.style.minHeight = height + 'px';

      // Create cursor element
      const cursor = document.createElement('span');
      cursor.style.cssText = 'display:inline-block;width:2px;background:#c8ff00;margin-left:1px;vertical-align:text-bottom;animation:blink 0.8s step-end infinite;';
      cursor.style.height = window.getComputedStyle(subtext).lineHeight;

      subtext.textContent = '';
      subtext.appendChild(cursor);

      let i = 0;
      setTimeout(() => {
        const typeInterval = setInterval(() => {
          // Insert character before cursor
          cursor.before(fullText[i]);
          i++;
          if (i >= fullText.length) {
            clearInterval(typeInterval);
            setTimeout(() => cursor.remove(), 1000);
          }
        }, 25);
      }, 2800);
    }
  }
</script>
