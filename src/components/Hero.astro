<section class="relative min-h-screen flex flex-col justify-end pb-12 md:pb-24 overflow-hidden" id="hero">
  <!-- Ambient light -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] md:w-[800px] h-[400px] md:h-[600px] bg-accent/5 rounded-full blur-[120px] md:blur-[200px]"></div>

  <!-- Particle canvas — desktop only -->
  <canvas id="particles-canvas" class="hidden md:block"></canvas>

  <!-- Main content -->
  <div class="relative z-10 max-w-[1400px] mx-auto px-4 md:px-8 w-full hero-content">
    <!-- Small label -->
    <div class="mb-6 md:mb-8">
      <div class="text-text-secondary text-xs tracking-[0.2em] md:tracking-[0.3em] uppercase">
        Webové stránky pro firmy a živnostníky
      </div>
    </div>

    <!-- Hero headline — word reveal -->
    <h1 class="hero-h1 text-[clamp(2.2rem,8vw,8rem)] font-bold leading-[0.95] tracking-tight" id="hero-h1">
      Váš web je vaše<br/>
      <span class="text-accent">vizitka</span>
    </h1>

    <!-- Bottom bar -->
    <div class="mt-10 md:mt-16 flex flex-col md:flex-row items-start md:items-end justify-between gap-6 md:gap-8 border-t border-dark-border pt-6 md:pt-8">
      <p class="text-text-secondary text-base md:text-xl max-w-md leading-relaxed">
        Profesionální web nemusí stát desítky tisíc.
        Vytvořím vám stránky, které udělají dojem — za férovou cenu.
      </p>

      <div class="flex items-center gap-6">
        <a
          href="#kontakt"
          class="magnetic-btn group flex items-center gap-3 text-white"
          data-hover
        >
          <span class="text-sm md:text-base tracking-wider uppercase">Chci nový web</span>
          <span class="w-10 h-10 md:w-12 md:h-12 rounded-full border border-accent/40 flex items-center justify-center group-hover:bg-accent group-hover:border-accent transition-all duration-500">
            <svg class="w-4 h-4 text-accent group-hover:text-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll line — hidden on mobile -->
  <div class="hidden md:block absolute bottom-0 left-8 w-px h-16 bg-gradient-to-b from-transparent to-accent/30"></div>
</section>

<!-- Particles — desktop only -->
<script>
  if (window.innerWidth >= 768) {
    const canvas = document.getElementById('particles-canvas') as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext('2d')!;
      let particles: { x: number; y: number; vx: number; vy: number; size: number; opacity: number; color: string }[] = [];
      const colors = ['59, 130, 246', '139, 92, 246', '245, 158, 11'];

      function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
      function createParticles() {
        const count = Math.floor((canvas.width * canvas.height) / 25000);
        particles = [];
        for (let i = 0; i < count; i++) {
          particles.push({
            x: Math.random() * canvas.width, y: Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * 0.15, vy: (Math.random() - 0.5) * 0.15,
            size: Math.random() * 1.5 + 0.3, opacity: Math.random() * 0.3 + 0.05,
            color: colors[Math.floor(Math.random() * colors.length)],
          });
        }
      }
      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach((p, i) => {
          p.x += p.vx; p.y += p.vy;
          if (p.x < 0) p.x = canvas.width; if (p.x > canvas.width) p.x = 0;
          if (p.y < 0) p.y = canvas.height; if (p.y > canvas.height) p.y = 0;
          ctx.beginPath(); ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${p.color}, ${p.opacity})`; ctx.fill();
          for (let j = i + 1; j < particles.length; j++) {
            const dx = p.x - particles[j].x, dy = p.y - particles[j].y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 130) {
              ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(particles[j].x, particles[j].y);
              ctx.strokeStyle = `rgba(${p.color}, ${0.04 * (1 - dist / 130)})`; ctx.lineWidth = 0.5; ctx.stroke();
            }
          }
        });
        requestAnimationFrame(draw);
      }
      resize(); createParticles(); draw();
      window.addEventListener('resize', () => { resize(); createParticles(); });
    }
  }
</script>

<!-- Hero animations after loader -->
<script>
  // Word-by-word reveal for H1
  const h1 = document.getElementById('hero-h1');
  if (h1) {
    const html = h1.innerHTML;
    const lines = html.split(/<br\s*\/?>/i);
    let wordIndex = 0;
    const processed = lines.map((line) => {
      return line.replace(/(<[^>]+>)|(\S+)/g, (match, tag, word) => {
        if (tag) return tag;
        wordIndex++;
        return `<span class="word"><span class="word-inner" style="transition-delay: ${wordIndex * 0.15}s">${word}</span></span>`;
      });
    });
    h1.innerHTML = processed.join('<br/>');
  }

  // Trigger after loader
  setTimeout(() => {
    const content = document.querySelector('.hero-content');
    if (content) content.classList.add('visible');
    if (h1) h1.classList.add('revealed');
  }, 1500);
</script>
