---
import data from '../content/marquee.json';
---

<div class="py-12 border-y border-dark-border overflow-hidden">
  <div class="flex whitespace-nowrap">
    <div class="marquee-track flex items-center gap-12 text-text-muted text-base tracking-[0.3em] uppercase">
      {data.items.map((item) => (
        <><span>{item}</span><span class="text-accent text-lg">&bull;</span></>
      ))}
      {/* Duplicate for seamless loop */}
      {data.items.map((item) => (
        <><span>{item}</span><span class="text-accent text-lg">&bull;</span></>
      ))}
    </div>
  </div>
</div>
