---
const projects = [
  {
    title: 'Úspor ne vytápěním',
    category: 'Firemní web',
    year: '2025',
    url: 'https://uspornevytapeni.cz',
    image: '/portfolio/uspornevytapeni.png',
    description: 'Web pro specialistu na tepelná čerpadla a úspory energií.',
  },
  {
    title: 'Union Power',
    category: 'Firemní prezentace',
    year: '2025',
    url: 'https://unionpower.cz',
    image: '/portfolio/unionpower.png',
    description: 'Prezentace lisovny plastů s moderním designem.',
  },
  {
    title: '2Brothers Music Factory',
    category: 'Osobní web',
    year: '2025',
    url: 'https://2brothers.cz',
    image: '/portfolio/2brothers.png',
    description: 'Web pro DJ duo s tmavým, energickým vizuálem.',
  },
  {
    title: 'Batmetal',
    category: 'Firemní web',
    year: '2025',
    url: '#',
    image: '/portfolio/batmetal.png',
    description: 'Průmyslové přípravky pro automobilový průmysl. Připravuje se.',
  },
];
---

<section id="prace" class="py-32 md:py-44 horizontal-scroll-section min-h-[200vh]">
  <div class="max-w-[1400px] mx-auto px-8 mb-16">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 reveal">
      <div>
        <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-4">Portfolio</div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight">
          Vybrané <span class="text-accent">práce</span>
        </h2>
      </div>
      <p class="text-text-secondary max-w-sm text-sm leading-relaxed">
        Každý projekt je unikátní příběh. Zde je výběr těch, na které jsme nejvíc pyšní.
      </p>
    </div>
  </div>

  <!-- Horizontal scrolling cards -->
  <div class="relative overflow-hidden" id="portfolio-container">
    <div class="horizontal-scroll-track px-8" id="portfolio-track">
      {projects.map((project) => (
        <a href={project.url} target="_blank" rel="noopener noreferrer" class="shrink-0 w-[85vw] md:w-[45vw] lg:w-[35vw] group block" data-hover>
          <div class="relative h-[50vh] md:h-[60vh] bg-dark-card rounded-xl overflow-hidden">
            <!-- Screenshot -->
            <img
              src={project.image}
              alt={project.title}
              class="absolute inset-0 w-full h-full object-contain transition-transform duration-700 group-hover:scale-105"
            />

            <!-- Bottom gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>

            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-all duration-700 flex items-center justify-center">
              <div class="opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0">
                <div class="w-16 h-16 rounded-full border border-accent flex items-center justify-center bg-accent/10 backdrop-blur-sm">
                  <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
                  </svg>
                </div>
              </div>
            </div>

            <!-- Bottom info overlay -->
            <div class="absolute bottom-0 left-0 right-0 p-6 z-10">
              <p class="text-white/50 text-sm">{project.description}</p>
            </div>
          </div>

          <!-- Project info -->
          <div class="mt-5 flex items-start justify-between">
            <div>
              <h3 class="text-lg font-semibold group-hover:text-accent transition-colors duration-500">{project.title}</h3>
              <p class="text-text-secondary text-sm mt-1">{project.category}</p>
            </div>
            <span class="text-text-muted text-sm font-mono">{project.year}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Horizontal scroll script -->
<script>
  const track = document.getElementById('portfolio-track');
  const container = document.getElementById('portfolio-container');

  if (track && container) {
    let scrollAmount = 0;
    const speed = 1.3;

    window.addEventListener('scroll', () => {
      const rect = container.getBoundingClientRect();
      const viewportHeight = window.innerHeight;

      if (rect.top < viewportHeight && rect.bottom > 0) {
        const progress = (viewportHeight - rect.top) / (viewportHeight + rect.height);
        const maxScroll = track.scrollWidth - container.clientWidth;
        scrollAmount = progress * maxScroll * speed;
        track.style.transform = `translateX(-${Math.max(0, scrollAmount)}px)`;
      }
    });
  }
</script>
