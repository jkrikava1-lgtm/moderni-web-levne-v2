---
const projects = [
  {
    title: 'Úsporné vytápění',
    category: 'Firemní web',
    year: '2025',
    url: 'https://uspornevytapeni.cz',
    image: '/portfolio/uspornevytapeni.jpg',
    description: 'Web pro specialistu na tepelná čerpadla a úspory energií.',
  },
  {
    title: 'Union Power',
    category: 'Firemní prezentace',
    year: '2025',
    url: 'https://unionpower.cz',
    image: '/portfolio/unionpower.jpg',
    description: 'Prezentace lisovny plastů s moderním designem.',
  },
  {
    title: '2Brothers Music Factory',
    category: 'Osobní web',
    year: '2025',
    url: 'https://2brothers.cz',
    image: '/portfolio/2brothers.jpg',
    description: 'Web pro DJ duo s tmavým, energickým vizuálem.',
  },
  {
    title: 'Batmetal',
    category: 'Firemní web',
    year: '2025',
    url: '#',
    image: '/portfolio/batmetal.jpg',
    description: 'Průmyslové přípravky pro automobilový průmysl. Připravuje se.',
  },
  {
    title: 'Zajíčkův vinný bar',
    category: 'Restaurace',
    year: '2025',
    url: '#',
    image: '/portfolio/zajickuv-vinny-bar.jpg',
    description: 'Vinný bar s tapas v Jičíně. Připravuje se.',
  },
];
---

<section id="ukazky" class="pt-12 md:pt-16 pb-24 md:pb-32 overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-4 md:px-8 mb-14">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 reveal">
      <div>
        <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-4">Ukázky</div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight">
          Jak vypadají naše <span class="text-accent">weby</span>
        </h2>
      </div>
      <p class="text-text-secondary max-w-md text-lg leading-relaxed">
        Podívejte se, jak vypadají weby, které jsem vytvořil pro firmy jako je ta vaše.
      </p>
    </div>
  </div>

  <!-- Infinite loop carousel -->
  <div class="relative" id="portfolio-carousel">
    <div class="flex gap-3 md:gap-5 portfolio-track pl-4 md:pl-0" id="portfolio-track">
      {/* Render cards 3x for seamless loop */}
      {[...projects, ...projects, ...projects].map((project) => (
        <a
          href={project.url}
          target={project.url !== '#' ? '_blank' : undefined}
          rel={project.url !== '#' ? 'noopener noreferrer' : undefined}
          class="shrink-0 w-[75vw] sm:w-[60vw] md:w-[50vw] lg:w-[40vw] group block"
          data-hover
        >
          <!-- Top: category + year -->
          <div class="flex items-center justify-between mb-3">
            <span class="text-[10px] text-text-muted tracking-wider uppercase">{project.category}</span>
            <span class="text-text-muted text-xs font-mono">{project.year}</span>
          </div>

          <!-- Screenshot -->
          <div class="relative aspect-[16/10] bg-dark-card rounded-xl overflow-hidden">
            <img
              src={project.image}
              alt={project.title}
              loading="lazy"
              class="absolute inset-0 w-full h-full object-cover object-top transition-all duration-[1.2s] ease-out group-hover:scale-[1.05]"
            />
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all duration-700 flex items-center justify-center">
              <div class="opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-3 group-hover:translate-y-0">
                <div class="w-14 h-14 rounded-full border border-accent flex items-center justify-center bg-accent/10 backdrop-blur-sm">
                  <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
                  </svg>
                </div>
              </div>
            </div>
          </div>

          <!-- Bottom: title + description -->
          <div class="mt-4">
            <h3 class="text-lg font-semibold group-hover:text-accent transition-colors duration-500">{project.title}</h3>
            <p class="text-text-secondary text-sm mt-1.5 leading-relaxed">{project.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  // JS-driven infinite scroll for pixel-perfect seamless loop
  const track = document.getElementById('portfolio-track');
  if (track) {
    let pos = 0;
    const speed = 1.5; // px per frame
    let paused = false;
    let rafId: number;

    // Calculate width of one set of cards
    const cards = track.children;
    const totalCards = cards.length;
    const oneSetCount = totalCards / 3; // we rendered 3 copies
    let oneSetWidth = 0;

    function measureSet() {
      oneSetWidth = 0;
      const gap = 20; // gap-5 = 1.25rem = 20px
      for (let i = 0; i < oneSetCount; i++) {
        oneSetWidth += (cards[i] as HTMLElement).offsetWidth + gap;
      }
    }

    measureSet();
    window.addEventListener('resize', measureSet);

    function animate() {
      if (!paused) {
        pos -= speed;
        if (Math.abs(pos) >= oneSetWidth) {
          pos += oneSetWidth;
        }
        track.style.transform = `translateX(${pos}px)`;
      }
      rafId = requestAnimationFrame(animate);
    }

    track.addEventListener('mouseenter', () => { paused = true; });
    track.addEventListener('mouseleave', () => { paused = false; });

    animate();
  }
</script>
