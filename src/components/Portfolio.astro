---
const projects = [
  {
    title: 'Úspor ne vytápěním',
    category: 'Firemní web',
    year: '2025',
    url: 'https://uspornevytapeni.cz',
    image: '/portfolio/uspornevytapeni.png',
    description: 'Web pro specialistu na tepelná čerpadla a úspory energií.',
  },
  {
    title: 'Union Power',
    category: 'Firemní prezentace',
    year: '2025',
    url: 'https://unionpower.cz',
    image: '/portfolio/unionpower.png',
    description: 'Prezentace lisovny plastů s moderním designem.',
  },
  {
    title: '2Brothers Music Factory',
    category: 'Osobní web',
    year: '2025',
    url: 'https://2brothers.cz',
    image: '/portfolio/2brothers.png',
    description: 'Web pro DJ duo s tmavým, energickým vizuálem.',
  },
  {
    title: 'Batmetal',
    category: 'Firemní web',
    year: '2025',
    url: '#',
    image: '/portfolio/batmetal.png',
    description: 'Průmyslové přípravky pro automobilový průmysl. Připravuje se.',
  },
];
---

<section id="prace" class="py-32 md:py-44 overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-8 mb-16">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 reveal">
      <div>
        <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-4">Portfolio</div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight">
          Vybrané <span class="text-accent">práce</span>
        </h2>
      </div>
      <p class="text-text-secondary max-w-sm text-sm leading-relaxed">
        Každý projekt je unikátní příběh. Zde je výběr těch, na které jsme nejvíc pyšní.
      </p>
    </div>
  </div>

  <!-- Infinite loop carousel -->
  <div class="relative" id="portfolio-carousel">
    <div class="flex gap-5 portfolio-track" id="portfolio-track">
      {/* Render cards 3x for seamless loop */}
      {[...projects, ...projects, ...projects].map((project) => (
        <a
          href={project.url}
          target={project.url !== '#' ? '_blank' : undefined}
          rel={project.url !== '#' ? 'noopener noreferrer' : undefined}
          class="shrink-0 w-[80vw] sm:w-[45vw] md:w-[30vw] lg:w-[23vw] group block"
          data-hover
        >
          <div class="relative aspect-[3/4] bg-dark-card rounded-xl overflow-hidden">
            <!-- Screenshot -->
            <img
              src={project.image}
              alt={project.title}
              class="absolute inset-0 w-full h-full object-cover object-top transition-all duration-[1.2s] ease-out group-hover:scale-[1.05]"
            />

            <!-- Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent group-hover:from-black/50 group-hover:via-transparent transition-all duration-700"></div>

            <!-- Top badge -->
            <div class="absolute top-4 left-4 z-10">
              <span class="px-2.5 py-1 bg-white/5 backdrop-blur-md border border-white/10 rounded-full text-[10px] text-white/50 tracking-wider uppercase">
                {project.category}
              </span>
            </div>

            <!-- Bottom info -->
            <div class="absolute bottom-0 left-0 right-0 p-5 z-10">
              <h3 class="text-base font-semibold text-white group-hover:text-accent transition-colors duration-500">
                {project.title}
              </h3>
              <p class="text-white/30 text-xs mt-1.5 leading-relaxed group-hover:text-white/50 transition-colors duration-500">
                {project.description}
              </p>

              <!-- Arrow -->
              <div class="mt-4 flex items-center gap-2 opacity-0 translate-y-3 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500">
                <span class="text-accent text-xs tracking-wider uppercase">Zobrazit</span>
                <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .portfolio-track {
    animation: portfolio-scroll 25s linear infinite;
  }

  .portfolio-track:hover {
    animation-play-state: paused;
  }

  @keyframes portfolio-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-1 * (23vw + 1.25rem) * 4));
    }
  }

  @media (max-width: 1024px) {
    @keyframes portfolio-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(calc(-1 * (30vw + 1.25rem) * 4)); }
    }
  }

  @media (max-width: 768px) {
    @keyframes portfolio-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(calc(-1 * (45vw + 1.25rem) * 4)); }
    }
  }

  @media (max-width: 640px) {
    @keyframes portfolio-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(calc(-1 * (80vw + 1.25rem) * 4)); }
    }
  }
</style>
