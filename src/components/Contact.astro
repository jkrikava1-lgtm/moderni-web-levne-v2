---
---

<section id="kontakt" class="py-24 md:py-32">
  <div class="max-w-[1400px] mx-auto px-8">
    <div class="reveal">
      <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-4">Kontakt</div>
    </div>

    <!-- Big CTA text -->
    <div class="reveal mb-14">
      <h2 class="text-5xl md:text-7xl lg:text-[6rem] font-bold tracking-tight leading-[1]">
        Chcete web, za který<br/>
        <span class="text-accent">se nebudete stydět?</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-16 md:gap-24">
      <!-- Left: form -->
      <div class="reveal">
        <form class="space-y-6" id="contact-form">
          <div>
            <input
              type="text"
              name="name"
              required
              placeholder="Jméno"
              class="w-full bg-transparent border-b border-dark-border py-4 text-white placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors duration-500"
            />
          </div>
          <div>
            <input
              type="email"
              name="email"
              required
              placeholder="Email"
              class="w-full bg-transparent border-b border-dark-border py-4 text-white placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors duration-500"
            />
          </div>
          <div>
            <select
              name="project-type"
              class="w-full bg-transparent border-b border-dark-border py-4 text-text-muted focus:outline-none focus:border-accent transition-colors duration-500"
            >
              <option value="" class="bg-dark">Typ projektu</option>
              <option value="new" class="bg-dark">Nový web</option>
              <option value="redesign" class="bg-dark">Redesign</option>
              <option value="other" class="bg-dark">Jiné</option>
            </select>
          </div>
          <div>
            <textarea
              name="message"
              rows="3"
              required
              placeholder="Popište svůj projekt..."
              class="w-full bg-transparent border-b border-dark-border py-4 text-white placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors duration-500 resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="magnetic-btn group mt-4 flex items-center gap-4"
            data-hover
          >
            <span class="text-sm tracking-wider uppercase text-white">Odeslat poptávku</span>
            <span class="w-14 h-14 rounded-full border border-accent/40 flex items-center justify-center group-hover:bg-accent group-hover:border-accent transition-all duration-500">
              <svg class="w-5 h-5 text-accent group-hover:text-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </span>
          </button>
        </form>
      </div>

      <!-- Right: info -->
      <div class="reveal reveal-delay-1 flex flex-col justify-between">
        <div class="space-y-10">
          <div>
            <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-2">Email</div>
            <a href="mailto:info@moderniweb.cz" class="text-lg text-white hover:text-accent transition-colors" data-hover>
              info@moderniweb.cz
            </a>
          </div>
          <div>
            <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-2">Telefon</div>
            <a href="tel:+420777724573" class="text-lg text-white hover:text-accent transition-colors" data-hover>
              +420 777 724 573
            </a>
          </div>
          <div>
            <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-2">Odezva</div>
            <p class="text-lg text-white">Do 24 hodin</p>
          </div>
        </div>

        <div class="mt-12 pt-8 border-t border-dark-border">
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
            <span class="text-text-secondary text-sm">Aktuálně přijímáme nové projekty</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
