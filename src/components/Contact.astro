---
import data from '../content/contact.json';
---

<section id="kontakt" class="py-24 md:py-32">
  <div class="max-w-[1400px] mx-auto px-4 md:px-8">
    <div class="reveal">
      <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-4">Kontakt</div>
    </div>

    <div class="reveal mb-14">
      <h2 class="text-5xl md:text-7xl lg:text-[6rem] font-bold tracking-tight leading-[1]">
        {data.heading_line1}<br/>
        <span class="text-accent">{data.heading_accent}</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-16 md:gap-24">
      <div class="reveal">
        <form class="space-y-6" id="contact-form">
          <div>
            <input type="text" name="name" required placeholder="Jméno"
              class="w-full bg-transparent border-b border-dark-border py-4 text-white placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors duration-500" />
          </div>
          <div>
            <input type="email" name="email" required placeholder="Email"
              class="w-full bg-transparent border-b border-dark-border py-4 text-white placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors duration-500" />
          </div>
          <div>
            <input type="tel" name="phone" placeholder="Telefon"
              class="w-full bg-transparent border-b border-dark-border py-4 text-white placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors duration-500" />
          </div>
          <div>
            <select name="project-type"
              class="w-full bg-transparent border-b border-dark-border py-4 text-text-muted focus:outline-none focus:border-accent transition-colors duration-500">
              <option value="" class="bg-dark">Typ projektu</option>
              <option value="new" class="bg-dark">Nový web</option>
              <option value="redesign" class="bg-dark">Redesign</option>
              <option value="other" class="bg-dark">Jiné</option>
            </select>
          </div>
          <div>
            <textarea name="message" rows="3" required placeholder="Popište svůj projekt..."
              class="w-full bg-transparent border-b border-dark-border py-4 text-white placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors duration-500 resize-none"></textarea>
          </div>
          <div id="form-status" class="hidden py-3 text-center rounded-lg"></div>

          <button type="submit" id="submit-btn" class="magnetic-btn group mt-4 flex items-center gap-4" data-hover>
            <span class="text-base tracking-wider uppercase text-white" id="submit-text">Odeslat poptávku</span>
            <span class="w-14 h-14 rounded-full border border-accent/40 flex items-center justify-center group-hover:bg-accent group-hover:border-accent transition-all duration-500">
              <svg class="w-5 h-5 text-accent group-hover:text-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </span>
          </button>
        </form>

        <script is:inline>
          document.addEventListener('DOMContentLoaded', function() {
            var form = document.getElementById('contact-form');
            var status = document.getElementById('form-status');
            var submitText = document.getElementById('submit-text');

            if (form) {
              form.addEventListener('submit', function(e) {
                e.preventDefault();
                submitText.textContent = 'Odesílám...';

                var formData = new FormData(form);
                var data = {};
                formData.forEach(function(value, key) { data[key] = value; });

                fetch('https://api.web3forms.com/submit', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    access_key: 'd208c7fb-2ac7-426d-bd06-1fdb9c4801e2',
                    subject: 'Nová poptávka z hezkewebovky.cz: ' + data.name,
                    from_name: 'Hezké webovky',
                    name: data.name,
                    email: data.email,
                    phone: data.phone || 'Neuvedeno',
                    'Typ projektu': data['project-type'] || 'Neuvedeno',
                    message: data.message
                  })
                }).then(function(res) {
                  if (res.ok) {
                    status.textContent = 'Děkujeme! Ozveme se vám do 24 hodin.';
                    status.className = 'py-3 text-center rounded-lg bg-accent/10 text-accent';
                    form.reset();
                  } else {
                    throw new Error();
                  }
                }).catch(function() {
                  status.textContent = 'Něco se pokazilo. Zkuste to znovu nebo nám napište na email.';
                  status.className = 'py-3 text-center rounded-lg bg-red-500/10 text-red-400';
                }).finally(function() {
                  submitText.textContent = 'Odeslat poptávku';
                });
              });
            }
          });
        </script>
      </div>

      <div class="reveal reveal-delay-1 flex flex-col justify-between">
        <div class="space-y-10">
          <div>
            <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-2">Kontaktní osoba</div>
            <p class="text-lg text-white">{data.contact_person}</p>
          </div>
          <div>
            <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-2">Email</div>
            <a href={`mailto:${data.email}`} class="text-lg text-white hover:text-accent transition-colors" data-hover>
              {data.email}
            </a>
          </div>
          <div>
            <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-2">Telefon</div>
            <a href={`tel:${data.phone_link}`} class="text-lg text-white hover:text-accent transition-colors" data-hover>
              {data.phone}
            </a>
          </div>
          <div>
            <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-2">Odezva</div>
            <p class="text-lg text-white">{data.response_time}</p>
          </div>
        </div>

        <div class="mt-12 pt-8 border-t border-dark-border">
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
            <span class="text-text-secondary text-base">{data.availability}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
