---
import data from '../content/pricing.json';
---

<section id="cena" class="py-24 md:py-32 border-t border-dark-border">
  <div class="max-w-[1400px] mx-auto px-4 md:px-8">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div class="reveal">
        <div class="text-text-muted text-xs tracking-[0.3em] uppercase mb-4">Proč u nás</div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-6">
          {data.heading}<br/><span class="text-accent">{data.heading_accent}</span>
        </h2>
        <p class="text-text-secondary text-lg leading-relaxed max-w-md">
          {data.subtext}
        </p>
        <div class="mt-8 flex items-baseline gap-2">
          <span class="text-4xl md:text-5xl font-bold text-accent">{data.price}</span>
          <span class="text-text-muted text-base">{data.price_note}</span>
        </div>
      </div>

      <div class="space-y-0 reveal reveal-delay-1">
        {data.reasons.map((reason, i) => (
          <div class={`py-6 ${i < data.reasons.length - 1 ? 'border-b border-dark-border' : ''}`}>
            <h3 class="text-lg font-semibold mb-2">{reason.title}</h3>
            <p class="text-text-secondary text-base leading-relaxed">{reason.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
