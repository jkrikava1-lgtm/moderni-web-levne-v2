---
const year = new Date().getFullYear();
---

<footer class="border-t border-dark-border py-8">
  <div class="max-w-[1400px] mx-auto px-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <img src="/logo.png" alt="Moderní Web" class="h-5 brightness-0 invert opacity-50" />
      <span class="text-text-muted text-xs tracking-wider">&copy; {year} Všechna práva vyhrazena.</span>
    </div>
    <a href="#hero" class="text-text-muted hover:text-accent text-xs tracking-wider uppercase transition-colors" data-hover>
      Zpět nahoru
    </a>
  </div>
</footer>
