---
const year = new Date().getFullYear();
---

<footer class="border-t border-dark-border py-8">
  <div class="max-w-[1400px] mx-auto px-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2 text-text-muted">
      <svg class="h-4 w-4" viewBox="0 0 32 32" fill="none"><path d="M6 2L6 22L10 18L14 24L18 22L14 16L20 16L6 2Z" fill="currentColor"/></svg>
      <span class="text-xs tracking-wider">hezké<span class="font-bold">webovky</span> &middot; &copy; {year}</span>
    </div>
    <a href="#hero" class="text-text-muted hover:text-accent text-xs tracking-wider uppercase transition-colors" data-hover>
      Zpět nahoru
    </a>
  </div>
</footer>
