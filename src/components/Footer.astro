---
const year = new Date().getFullYear();
---

<footer class="border-t border-dark-border py-8">
  <div class="max-w-[1400px] mx-auto px-4 md:px-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2 text-text-muted" style="font-family: 'Nunito', sans-serif;">
      <img src="/icon-cursor.png" alt="" class="h-4 object-contain opacity-40" />
      <span class="text-sm tracking-wider"><span class="font-bold" style="font-family: 'Inter', sans-serif;">hezké</span><span class="font-light" style="font-family: 'Nunito', sans-serif;">webovky</span> &middot; &copy; {year}</span>
    </div>
    <button onclick="window.history.replaceState({}, '', '/'); window.scrollTo({top: 0, behavior: 'smooth'})" class="text-text-muted hover:text-accent text-xs tracking-wider uppercase transition-colors cursor-pointer" data-hover>
      Zpět nahoru
    </button>
  </div>
</footer>
